# --- Public site facts (safe to expose; inlined into the client bundle) ---
NEXT_PUBLIC_SITE_URL=https://www.webify.org.in
NEXT_PUBLIC_CONTACT_EMAIL=contact@webify.org.in

# Synchronous contact channels — set these and the WhatsApp button, phone link,
# and calendar embed appear automatically. Leave blank to hide each one.
NEXT_PUBLIC_WHATSAPP=          # digits only, country code first, e.g. 919876543210
NEXT_PUBLIC_PHONE=             # e.g. +91 98765 43210
NEXT_PUBLIC_CAL_URL=           # e.g. https://cal.com/webify/intro

# Business location (shown in schema; optional)
NEXT_PUBLIC_CITY=
NEXT_PUBLIC_REGION=
NEXT_PUBLIC_COUNTRY=India

# Social profiles — only configured ones render (no dead links).
NEXT_PUBLIC_LINKEDIN=
NEXT_PUBLIC_GITHUB=
NEXT_PUBLIC_X=

# --- Server-only (NEVER prefixed NEXT_PUBLIC_) ---
# Resend powers the contact form. Get a key at https://resend.com and verify
# your sending domain. Until RESEND_API_KEY is set, the form fails gracefully
# and tells visitors to email you directly.
RESEND_API_KEY=
CONTACT_TO_EMAIL=contact@webify.org.in       # where form submissions are delivered
EMAIL_FROM=Webify <contact@webify.org.in>    # must be a Resend-verified sender

# Optional: live "currently reading" shelf (unused by default)
NEXT_PUBLIC_GOODREADS_USER_ID=
